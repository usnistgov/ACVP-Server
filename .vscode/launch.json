    "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Launch ASP.NET Core App",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/gen-val/samples/GenValAppRunner/src/bin/Debug/net9.0/NIST.CVP.ACVTS.Generation.GenValApp.dll",
      "args": [],
      "cwd": "${workspaceFolder}/gen-val/samples/GenValAppRunner",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
        

    ]
}